TRACKBRIDGE_ENV=development
TRACKBRIDGE_DOMAIN=localhost
TRACKBRIDGE_ACME_EMAIL=admin@example.com
TRACKBRIDGE_API_URL=http://localhost:8000
TRACKBRIDGE_FRONTEND_URL=http://localhost:5173
TRACKBRIDGE_PUBLIC_BASE_URL=http://localhost
TRACKBRIDGE_SECRET_KEY=change-me-before-production
TRACKBRIDGE_ACCESS_TOKEN_EXPIRE_MINUTES=60
TRACKBRIDGE_DATABASE_URL=postgresql+psycopg://trackbridge:trackbridge@postgres:5432/trackbridge
TRACKBRIDGE_REDIS_URL=redis://redis:6379/0
POSTGRES_DB=trackbridge
POSTGRES_USER=trackbridge
POSTGRES_PASSWORD=trackbridge

TRACKBRIDGE_SMTP_HOST=
TRACKBRIDGE_SMTP_PORT=587
TRACKBRIDGE_SMTP_USERNAME=
TRACKBRIDGE_SMTP_PASSWORD=
TRACKBRIDGE_SMTP_FROM=TrackBridge <noreply@example.com>
TRACKBRIDGE_SMTP_USE_TLS=true
TRACKBRIDGE_SMTP_USE_SSL=false
