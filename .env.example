TRACKBRIDGE_ENV=development
TRACKBRIDGE_DOMAIN=localhost
TRACKBRIDGE_ACME_EMAIL=admin@example.com
TRACKBRIDGE_API_URL=http://localhost:8000
TRACKBRIDGE_FRONTEND_URL=http://localhost:5173
TRACKBRIDGE_PUBLIC_BASE_URL=http://localhost
TRACKBRIDGE_SECRET_KEY=change-me-before-production
TRACKBRIDGE_ACCESS_TOKEN_EXPIRE_MINUTES=60
